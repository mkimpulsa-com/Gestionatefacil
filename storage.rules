rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Permitir lectura pública de productos para el catálogo si es necesario
    match /users/{userId}/products/{allPaths=**} {
      allow read: if true;
    }
  }
}
