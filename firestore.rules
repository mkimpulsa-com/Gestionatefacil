rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'guananjacarlosenrique@gmail.com';
    }

    // Admin Access (God Mode)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Users collection rules
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // General user rules for documents with userId field
    match /{collectionName}/{docId} {
      allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && (resource.data.userId == request.auth.uid || isAdmin()))
      );
    }
    
    // Public Catalog Access
    match /products/{productId} {
      allow read: if true;
    }
    
    match /companies/{companyId} {
      allow read: if true;
    }

    match /product_categories/{catId} {
      allow read: if true;
    }

    match /product_brands/{brandId} {
      allow read: if true;
    }
  }
}
